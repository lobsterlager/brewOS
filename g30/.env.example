# Grainfather BLE connection (required)
GF_BLE_ADDRESS=your-ble-address-here
GF_BLE_NAME=Grain

# Python binary (defaults to python3)
# GF_PYTHON=/path/to/your/venv/bin/python

# Dashboard server
# GF_DASHBOARD_PORT=8002
# GF_BIND_ADDRESS=127.0.0.1

# Logging
# GF_LOG_DIR=./logs
# GF_NOTIFY_LOG=1
# GF_USE_DEVICE_TIMER=0
